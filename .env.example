# ============================================================
# AI Research Assistant — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── Qdrant ───────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=research_papers
QDRANT_VECTOR_SIZE=768

# ── Embedding Model ─────────────────────────────────────────
# Best for Arabic+English:
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
# Faster (half size, slightly lower quality):
# EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_BATCH_SIZE=16
EMBEDDING_DEVICE=cpu   # Use "cuda" if Jetson CUDA is available

# ── Ollama / LLM ────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
# For better Arabic: OLLAMA_MODEL=aya
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048

# ── Worker ──────────────────────────────────────────────────
WORKER_PORT=8000
MAX_CONCURRENT_INGESTIONS=3

# ── Chunking ────────────────────────────────────────────────
CHUNK_SIZE=700
CHUNK_OVERLAP=120

# ── Storage ─────────────────────────────────────────────────
PDF_CACHE_DIR=/tmp/arxiv_pdfs
LOG_PATH=/tmp/ingestion.log

# ── Hardware ─────────────────────────────────────────────────
DEVICE_INFO=Jetson Nano 4GB

# ── n8n ─────────────────────────────────────────────────────────────
# Worker POSTs ingestion results to: {N8N_WEBHOOK_BASE}/webhook/ingestion-complete
N8N_WEBHOOK_BASE=http://localhost:5678
#
# To integrate n8n with the UI chatbot + “Ask AI” box on THIS app (worker/main.py):
# 1) Import repo file n8n/workflows.json into your n8n instance (local Docker or cloud).
# 2) Add HTTP/Webhook nodes that call back to this API:
#      POST {your-app}/webhook/chatbot   JSON: { "message", "history"?, "systemPrompt"? }
#      POST {your-app}/webhook/research JSON: { "question", "history"?, "systemPrompt"? }
#    Or run n8n on the same machine and proxy: the UI already calls /webhook/* on the same origin.
# 3) No separate “file upload” is required for chat wiring — only import the workflow JSON
#    and point nodes at your running FastAPI URL. For RAG, ingest PDFs via the UI/API first.

# ── Groq (required for chat webhooks, reports, RAG answers) ──
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# ── n8n → backend automation (set all three; match X-Webhook-Secret in n8n HTTP nodes — default in repo: dev-n8n-webhook-secret)
WEBHOOK_REPORT_SECRET=dev-n8n-webhook-secret
WEBHOOK_QUERY_SECRET=dev-n8n-webhook-secret
WEBHOOK_INGEST_SECRET=dev-n8n-webhook-secret

# Required for /webhook/research and /webhook/chatbot when caller is NOT using Bearer JWT (n8n, Telegram).
# Must match W3/W4 HTTP node header in n8n/workflows.json (default dev-n8n-llm-secret).
WEBHOOK_LLM_SECRET=dev-n8n-llm-secret

# Dev only: allow browser LLM webhooks without login (NOT for production).
ALLOW_ANONYMOUS_LLM_WEBHOOK=0

# Optional: POST before UI /ingest and /report (orchestration preflight for n8n).
# N8N_UI_PIPELINE_WEBHOOK=http://localhost:5678/webhook/ui-pipeline

# Optional: Telegram PDF → this n8n webhook first (workflow forwards to /webhook/ingest_pdf).
# N8N_PDF_INGEST_WEBHOOK=http://localhost:5678/webhook/pdf-ingest

# Optional: reject secondary routes with HTTP 409 (strict contract).
# ENFORCE_PRIMARY_ROUTES=0

# Optional: forward UI/Telegram chat to n8n first (n8n must POST back to this app or return model output)
# N8N_CHATBOT_WEBHOOK=http://localhost:5678/webhook/...
# N8N_RESEARCH_WEBHOOK=http://localhost:5678/webhook/...

# ── Optional Telegram bot (python telegram_bot.py) ──
# TELEGRAM_BOT_TOKEN=
# WORKER_BASE=http://127.0.0.1:8000
# TELEGRAM_LLM_PATH=/webhook/research
# N8N_TELEGRAM_GATEWAY_URL=http://localhost:5678/webhook/telegram-bridge

# ── Optional public web search API key (for SerpAPI search)
SERPAPI_API_KEY=
